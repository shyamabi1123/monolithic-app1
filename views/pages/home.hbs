<section class="hero">
  <h1>Welcome to MonolithApp</h1>
  <p>A full-stack monolithic Node.js application — all in one place.</p>
  <div class="hero-actions">
    <a href="/products" class="btn btn-primary">Browse Products</a>
    {{#unless user}}
      <a href="/auth/register" class="btn btn-secondary">Get Started</a>
    {{/unless}}
  </div>
</section>

<section class="features">
  <div class="feature-card">
    <h3>Products</h3>
    <p>Browse and search our full product catalogue.</p>
  </div>
  <div class="feature-card">
    <h3>Secure Checkout</h3>
    <p>Payments powered by Stripe — test mode ready.</p>
  </div>
  <div class="feature-card">
    <h3>Order Tracking</h3>
    <p>See all your orders and their status in one place.</p>
  </div>
</section>
